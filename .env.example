APP_NAME=Observability Watchdog
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://watchdog:watchdog@localhost:5432/watchdog
API_V1_PREFIX=/api/v1

# Used by docker-compose only (ignored by the Python app Settings model)
POSTGRES_USER=watchdog
POSTGRES_PASSWORD=watchdog
POSTGRES_DB=watchdog
POSTGRES_PORT=5432

LLM_PROVIDER=template
GEMINI_API_KEY=
OPENAI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=20
